# Spotify API credentials (required)
# Get them at: https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here

# Redirect URI — must match exactly what's registered in the Spotify dashboard.
#
# Spotify blocks all localhost URIs. You need to host callback.html (in the project
# root) somewhere with free HTTPS, then register that URL here and in the dashboard.
#
# Easiest option — GitHub Pages:
#   1. Create a repo (or use an existing one with Pages enabled)
#   2. Upload callback.html to it
#   3. Set the URL below to: https://YOURNAME.github.io/REPONAME/callback.html
#
SPOTIPY_REDIRECT_URI=https://YOURNAME.github.io/REPONAME/callback.html

# Optional: override default output directory
# SMARTSABER_OUTPUT_DIR=./output
